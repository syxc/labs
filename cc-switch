#!/usr/bin/env bash
# cc-switch - Switch Claude Code provider configuration
# Usage: cc-switch [options] <provider_name>
# Example: cc-switch glm

set -euo pipefail

readonly CONFIG_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
readonly SETTINGS_FILE="$CONFIG_DIR/settings.json"
readonly PROVIDERS_FILE="$CONFIG_DIR/providers.json"
readonly ZSHENV_ENV="$HOME/.zshenv.env"
readonly VERSION="1.0.0"

# Cleanup on exit
cleanup() {
  [[ -f "${SETTINGS_FILE}.tmp" ]] && rm -f "${SETTINGS_FILE}.tmp"
  return 0
}
trap cleanup EXIT

# Check dependencies
check_deps() {
  if ! command -v jq &> /dev/null; then
    echo "Error: jq is required. Install with: brew install jq" >&2
    exit 1
  fi
}

# Check files exist
check_files() {
  if [[ ! -f "$PROVIDERS_FILE" ]]; then
    echo "Error: Providers config not found: $PROVIDERS_FILE" >&2
    exit 1
  fi

  if [[ ! -f "$SETTINGS_FILE" ]]; then
    echo "Error: Settings file not found: $SETTINGS_FILE" >&2
    exit 1
  fi

  if [[ ! -f "$ZSHENV_ENV" ]]; then
    echo "Error: Zshenv env file not found: $ZSHENV_ENV" >&2
    exit 1
  fi
}

# List available providers
list_providers() {
  echo "Available providers:"
  jq -r 'to_entries[] | "  \(.key) - \(.value.name)"' "$PROVIDERS_FILE"
  echo ""

  local current_url
  current_url=$(jq -r '.env.ANTHROPIC_BASE_URL // ""' "$SETTINGS_FILE")

  if [[ -n "$current_url" ]]; then
    local current_name
    current_name=$(jq -r --arg url "$current_url" \
      'to_entries[] | select(.value.ANTHROPIC_BASE_URL == $url) | .key' \
      "$PROVIDERS_FILE" 2>/dev/null || echo "")

    if [[ -n "$current_name" ]]; then
      echo "Current: $current_name"
    else
      echo "Current: custom (not in providers.json)"
    fi
  else
    echo "Current: not configured"
  fi
}

# Validate providers.json configuration
validate_config() {
  local errors=0
  local warnings=0

  echo "Validating configuration..."
  echo ""

  # Check if providers.json is valid JSON
  if ! jq empty "$PROVIDERS_FILE" 2>/dev/null; then
    echo "ERROR: providers.json is not valid JSON"
    return 1
  fi

  # Check if settings.json is valid JSON
  if ! jq empty "$SETTINGS_FILE" 2>/dev/null; then
    echo "ERROR: settings.json is not valid JSON"
    return 1
  fi

  # Check each provider
  local providers
  providers=$(jq -r 'keys[]' "$PROVIDERS_FILE")

  for provider in $providers; do
    echo "Checking provider: $provider"

    # Check required fields
    local base_url auth_token_var model
    base_url=$(jq -r ".[\"$provider\"].ANTHROPIC_BASE_URL // empty" "$PROVIDERS_FILE")
    auth_token_var=$(jq -r ".[\"$provider\"].ANTHROPIC_AUTH_TOKEN_VAR // empty" "$PROVIDERS_FILE")
    model=$(jq -r ".[\"$provider\"].ANTHROPIC_MODEL // empty" "$PROVIDERS_FILE")

    if [[ -z "$base_url" ]]; then
      echo "  ERROR: ANTHROPIC_BASE_URL is missing"
      ((errors++))
    fi

    if [[ -z "$auth_token_var" ]]; then
      echo "  ERROR: ANTHROPIC_AUTH_TOKEN_VAR is missing"
      ((errors++))
    else
      # Check if environment variable exists
      if [[ -z "${!auth_token_var:-}" ]]; then
        echo "  WARNING: Environment variable \${$auth_token_var} is not set"
        ((warnings++))
      else
        echo "  OK: \${$auth_token_var} is set"
      fi
    fi

    if [[ -z "$model" ]]; then
      echo "  WARNING: ANTHROPIC_MODEL is not set"
      ((warnings++))
    fi

    # Check model variants
    local haiku sonnet opus
    haiku=$(jq -r ".[\"$provider\"].ANTHROPIC_DEFAULT_HAIKU_MODEL // empty" "$PROVIDERS_FILE")
    sonnet=$(jq -r ".[\"$provider\"].ANTHROPIC_DEFAULT_SONNET_MODEL // empty" "$PROVIDERS_FILE")
    opus=$(jq -r ".[\"$provider\"].ANTHROPIC_DEFAULT_OPUS_MODEL // empty" "$PROVIDERS_FILE")

    [[ -z "$haiku" ]] && echo "  WARNING: ANTHROPIC_DEFAULT_HAIKU_MODEL is not set" && ((warnings++))
    [[ -z "$sonnet" ]] && echo "  WARNING: ANTHROPIC_DEFAULT_SONNET_MODEL is not set" && ((warnings++))
    [[ -z "$opus" ]] && echo "  WARNING: ANTHROPIC_DEFAULT_OPUS_MODEL is not set" && ((warnings++))

    echo ""
  done

  # Check .zshenv.env
  echo "Checking .zshenv.env..."
  if [[ -f "$ZSHENV_ENV" ]]; then
    if grep -q "^export ANTHROPIC_AUTH_TOKEN=" "$ZSHENV_ENV"; then
      local token_var
      token_var=$(grep "^export ANTHROPIC_AUTH_TOKEN=" "$ZSHENV_ENV" | cut -d'=' -f2- | tr -d '"' | sed 's/\${//;s/}//')
      if [[ -n "${!token_var:-}" ]]; then
        echo "  OK: ANTHROPIC_AUTH_TOKEN -> \${$token_var}"
      else
        echo "  WARNING: \${$token_var} is not set"
        ((warnings++))
      fi
    else
      echo "  WARNING: ANTHROPIC_AUTH_TOKEN is not configured"
      ((warnings++))
    fi
  else
    echo "  ERROR: .zshenv.env not found"
    ((errors++))
  fi

  echo ""
  echo "=== Validation Summary ==="
  echo "Errors: $errors"
  echo "Warnings: $warnings"

  if [[ $errors -gt 0 ]]; then
    echo "Status: FAILED"
    return 1
  elif [[ $warnings -gt 0 ]]; then
    echo "Status: PASSED with warnings"
    return 0
  else
    echo "Status: OK"
    return 0
  fi
}

# Show current provider
show_current() {
  local base_url auth_token_var model
  base_url=$(jq -r '.env.ANTHROPIC_BASE_URL // "not set"' "$SETTINGS_FILE")
  auth_token_var=$(grep -E "^export ANTHROPIC_AUTH_TOKEN=" "$ZSHENV_ENV" 2>/dev/null | cut -d'=' -f2- || echo "not set")
  model=$(jq -r '.env.ANTHROPIC_MODEL // "not set"' "$SETTINGS_FILE")

  echo "Current configuration:"
  echo "  ANTHROPIC_BASE_URL: $base_url"
  echo "  ANTHROPIC_AUTH_TOKEN: \${$auth_token_var}"
  echo "  ANTHROPIC_MODEL: $model"
}

# Update ANTHROPIC_AUTH_TOKEN in .zshenv.env
update_auth_token() {
  local token_var="$1"

  # Backup .zshenv.env
  cp "$ZSHENV_ENV" "$ZSHENV_ENV.bak"

  # Update or add ANTHROPIC_AUTH_TOKEN
  if grep -q "^export ANTHROPIC_AUTH_TOKEN=" "$ZSHENV_ENV"; then
    # Replace existing line
    sed -i '' "s|^export ANTHROPIC_AUTH_TOKEN=.*|export ANTHROPIC_AUTH_TOKEN=\"\${${token_var}}\"|" "$ZSHENV_ENV"
  else
    # Add new line after the header comment
    echo "" >> "$ZSHENV_ENV"
    echo "# Claude Code - Auto-generated by cc-switch" >> "$ZSHENV_ENV"
    echo "export ANTHROPIC_AUTH_TOKEN=\"\${${token_var}}\"" >> "$ZSHENV_ENV"
  fi
}

# Switch provider
switch_provider() {
  local provider="$1"

  # Check if provider exists
  if ! jq -e ".[\"$provider\"]" "$PROVIDERS_FILE" > /dev/null 2>&1; then
    echo "Error: Unknown provider '$provider'" >&2
    echo "" >&2
    list_providers
    exit 1
  fi

  # Get provider config
  local config
  config=$(jq ".[\"$provider\"]" "$PROVIDERS_FILE")

  # Extract values
  local base_url auth_token_var model haiku sonnet opus
  base_url=$(echo "$config" | jq -r '.ANTHROPIC_BASE_URL // empty')
  auth_token_var=$(echo "$config" | jq -r '.ANTHROPIC_AUTH_TOKEN_VAR // empty')
  model=$(echo "$config" | jq -r '.ANTHROPIC_MODEL // empty')
  haiku=$(echo "$config" | jq -r '.ANTHROPIC_DEFAULT_HAIKU_MODEL // empty')
  sonnet=$(echo "$config" | jq -r '.ANTHROPIC_DEFAULT_SONNET_MODEL // empty')
  opus=$(echo "$config" | jq -r '.ANTHROPIC_DEFAULT_OPUS_MODEL // empty')

  # Validate required fields
  if [[ -z "$base_url" ]]; then
    echo "Error: ANTHROPIC_BASE_URL is required but empty" >&2
    exit 1
  fi

  if [[ -z "$auth_token_var" ]]; then
    echo "Error: ANTHROPIC_AUTH_TOKEN_VAR is required but empty" >&2
    exit 1
  fi

  # Check if the environment variable exists
  if [[ -z "${!auth_token_var:-}" ]]; then
    echo "Warning: Environment variable \${$auth_token_var} is not set or empty" >&2
  fi

  # Update .zshenv.env with new auth token variable
  update_auth_token "$auth_token_var"

  # Backup current settings
  if [[ -f "$SETTINGS_FILE" ]]; then
    [[ -f "$SETTINGS_FILE.bak.3" ]] && rm -f "$SETTINGS_FILE.bak.3"
    for i in 2 1; do
      [[ -f "$SETTINGS_FILE.bak.$i" ]] && mv "$SETTINGS_FILE.bak.$i" "$SETTINGS_FILE.bak.$((i+1))"
    done
    [[ -f "$SETTINGS_FILE.bak" ]] && mv "$SETTINGS_FILE.bak" "$SETTINGS_FILE.bak.1"
    cp "$SETTINGS_FILE" "$SETTINGS_FILE.bak"
  fi

  # Update settings.json (without ANTHROPIC_AUTH_TOKEN, it comes from env)
  jq \
    --arg base_url "$base_url" \
    --arg model "$model" \
    --arg haiku "$haiku" \
    --arg sonnet "$sonnet" \
    --arg opus "$opus" \
    '
    .env.ANTHROPIC_BASE_URL = $base_url |
    .env.ANTHROPIC_MODEL = $model |
    .env.ANTHROPIC_DEFAULT_HAIKU_MODEL = $haiku |
    .env.ANTHROPIC_DEFAULT_SONNET_MODEL = $sonnet |
    .env.ANTHROPIC_DEFAULT_OPUS_MODEL = $opus |
    del(.env.ANTHROPIC_AUTH_TOKEN)
    ' "$SETTINGS_FILE" > "$SETTINGS_FILE.tmp"

  mv "$SETTINGS_FILE.tmp" "$SETTINGS_FILE"

  local provider_name
  provider_name=$(jq -r ".[\"$provider\"].name" "$PROVIDERS_FILE")
  echo "Switched to: $provider_name"
  echo ""
  show_current
  echo ""

  # Reload shell configuration
  echo "Reloading shell configuration..."
  source "$ZSHENV_ENV" 2>/dev/null || true
  echo ""
  echo "Done! Restart Claude Code to apply changes."
}

# Show help
show_help() {
  cat << EOF
cc-switch v${VERSION} - Switch Claude Code provider configuration

Usage: cc-switch [options] [provider]

Options:
  -h, --help      Show this help message
  -l, --list      List available providers
  -s, --status    Show current provider status
  -v, --version   Show version
  --validate      Validate configuration

Providers:
$(jq -r 'to_entries[] | "  \(.key)\t\(.value.name)"' "$PROVIDERS_FILE" 2>/dev/null || echo "  (none)")

Examples:
  cc-switch glm         Switch to GLM provider
  cc-switch mimo        Switch to MiMo provider
  cc-switch -s          Show current configuration
  cc-switch --validate  Validate all configurations

Configuration:
  Providers file: $PROVIDERS_FILE
  Settings file:  $SETTINGS_FILE
  Env file:       $ZSHENV_ENV

Environment Variables:
  ANTHROPIC_AUTH_TOKEN is set via \${VAR} syntax in .zshenv.env
  Example: export ANTHROPIC_AUTH_TOKEN="\${ZAI_API_KEY}"
EOF
}

# Main
main() {
  check_deps
  check_files

  case "${1:-}" in
    "")
      list_providers
      ;;
    -h|--help)
      show_help
      ;;
    -l|--list)
      list_providers
      ;;
    -s|--status)
      show_current
      ;;
    -v|--version)
      echo "cc-switch v${VERSION}"
      ;;
    --validate)
      validate_config
      ;;
    -*)
      echo "Error: Unknown option '$1'" >&2
      echo "Run 'cc-switch --help' for usage." >&2
      exit 1
      ;;
    *)
      switch_provider "$1"
      ;;
  esac
}

main "$@"
